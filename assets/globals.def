0x2E0  byte[16]  FinderName     "Name of Finder"
0x900  sword     CurApRefNum    "Refnum of current application's resource file"
0x910  Str31     CurApName      "Name of current application"
0x934  sword     CurJTOffset    "Offset to jump table from A5"
