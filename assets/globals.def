0x102  sword  ScrVRes    "Pixels per inch vertically"
0x104  sword  ScrHRes    "Pixels per inch horizontally"
0x106  sword  ScreenRow  "Bytes per row of screen bitmap"
0x156  long   RndSeed    "Random number seed"
0x824  Ptr    ScrnBase   "Address of main screen buffer"
0x834  Rect   CrsrPin    "Rectangle for cursor pinning"

# ── WindowMgr ──

0x9D6  ^WindowRecord  WindowList    "Pointer to first window in window list"
0x9DA  sword          SaveUpdate    "Flag: generate update events"
0x9DC  sword          PaintWhite    "Flag: paint window white before update event"
0x9DE  ^GrafPort      WMgrPort      "Pointer to Window Manager port"
0x9EE  ^^Region       GrayRgn       "Handle to region drawn as desktop"
0x9F6  ProcPtr        DragHook      "Address of procedure during drag/track ops"
0xA34  Pattern        DragPattern   "Pattern of dragged region outline"
0xA3C  Pattern        DeskPattern   "Pattern for desktop painting"
0xA64  ^GrafPort      CurActivate   "Pointer to window to receive activate event"
0xA68  ^GrafPort      CurDeactive   "Pointer to window to receive deactivate event"
0xA6C  ProcPtr        DeskHook      "Procedure for painting/clicking desktop"
0xA84  ^GrafPort      GhostWindow   "Window never considered frontmost"

# ── MenuMgr ──

0xA0A  sword    TopMenuItem   "Pixel value of top of scrollable menu"
0xA0C  sword    AtMenuBottom  "Flag for menu scrolling"
0xA1C  Handle   MenuList      "Handle to current menu list"
0xA20  sword    MBarEnable    "Unique menu ID for active desk accessory"
