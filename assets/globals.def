# globals.def — Macintosh low-memory global definitions
#
# Format: <hex_addr>  <type>  <name>  "<description>"
#
# Types: primitives (byte, sbyte, word, sword, long, slong, Ptr,
#        Handle, ProcPtr, OSType, Boolean, OSErr) or struct names
#        from types.def (QHdr, Pattern, Rect, ScrapStuff, etc.).
# Arrays: <type>[N] — N elements packed contiguously.
#         For PStr[N], N is the total buffer size incl. length byte.
# Pointer/Handle to struct: ^StructName (4 bytes), ^^StructName (4 bytes).
# Commented-out entries: lines starting with #? are globals whose
#         System 6 status is uncertain.
# Sections: # ── SectionName ── comments group by THINK C 3 include file.
#
# Source of truth: THINK C 3 headers (System 6).

# ── MacTypes ──

0x28E  sword  ROM85  "Version number of ROM"

# ── MemoryMgr ──

0x108  Ptr      MemTop        "Address of end of RAM"
0x10C  Ptr      BufPtr        "Address of end of jump table"
0x114  Ptr      HeapEnd       "End of application heap zone"
0x118  ^Zone    TheZone       "Address of current heap zone"
0x130  Ptr      ApplLimit     "Application heap limit"
0x220  sword    MemErr        "Current value of MemError"
0x2A6  ^Zone    SysZone       "Address of system heap zone"
0x2AA  ^Zone    ApplZone      "Address of application heap zone"
0x2AE  Ptr      ROMBase       "Base address of ROM"
0x2B2  Ptr      RAMBase       "Trap dispatch table base for RAM routines"
0x31A  long     Lo3Bytes      "$00FFFFFF constant"
0x33C  ProcPtr  IAZNotify     "InitApplZone notify procedure"
0x904  Ptr      CurrentA5     "Boundary between app globals and app params"
0x908  Ptr      CurStackBase  "Address of base of stack; start of app globals"

# ── OSUtil ──

0x15A  sword        SysVersion  "System software version number"
0x1F8  SysParmType  SysParam    "Low-memory copy of parameter RAM"
0x20C  long         Time        "Seconds since midnight, January 1, 1904"

# ── EventMgr ──

0x144  sword    SysEvtMask     "System event mask"
0x14A  QHdr     EventQueue     "Event queue header"
0x15C  sbyte    SEvtEnb        "0 if SystemEvent returns FALSE"
0x16A  long     Ticks          "Tick count since startup"
0x18E  sword    KeyThresh      "Auto-key threshold"
0x190  sword    KeyRepThresh   "Auto-key repeat rate"
0x29A  ProcPtr  JGNEFilter     "GetNextEvent filter procedure"
0x29E  ProcPtr  Key1Trans      "Keyboard translator procedure 1"
0x2A2  ProcPtr  Key2Trans      "Keyboard translator procedure 2"
0x2F0  long     DoubleTime     "Double-click interval in ticks"
0x2F4  long     CaretTime      "Caret-blink interval in ticks"
0x2F8  sbyte    ScrDmpEnb      "0 if GetNextEvent ignores Cmd-Shift-number"

