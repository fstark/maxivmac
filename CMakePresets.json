{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "macos",
            "displayName": "macOS (SDL)",
            "description": "SDL backend on macOS",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MAXIVMAC_BACKEND": "sdl"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-headless",
            "displayName": "macOS (Headless)",
            "description": "Headless backend on macOS — no SDL, no window",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MAXIVMAC_BACKEND": "headless"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-imgui",
            "displayName": "macOS (ImGui)",
            "description": "Dear ImGui backend on macOS — debug UI",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MAXIVMAC_BACKEND": "imgui"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "linux",
            "displayName": "Linux (SDL)",
            "description": "SDL backend on Linux",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "windows",
            "displayName": "Windows (SDL)",
            "description": "SDL backend on Windows",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "macos",
            "configurePreset": "macos"
        },
        {
            "name": "macos-headless",
            "configurePreset": "macos-headless"
        },
        {
            "name": "macos-imgui",
            "configurePreset": "macos-imgui"
        },
        {
            "name": "linux",
            "configurePreset": "linux"
        },
        {
            "name": "windows",
            "configurePreset": "windows"
        }
    ]
}