{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "macos",
            "displayName": "macOS (ImGui)",
            "description": "Dear ImGui backend on macOS",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MAXIVMAC_BACKEND": "imgui"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-headless",
            "displayName": "macOS (Headless)",
            "description": "Headless backend on macOS — no SDL, no window",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MAXIVMAC_BACKEND": "headless"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-coverage",
            "displayName": "macOS (Headless + Coverage)",
            "description": "Headless backend with code-coverage instrumentation",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "MAXIVMAC_BACKEND": "headless",
                "MAXIVMAC_COVERAGE": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-asan",
            "displayName": "macOS (Headless + ASan/UBSan)",
            "description": "Headless backend with AddressSanitizer and UndefinedBehaviorSanitizer",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "MAXIVMAC_BACKEND": "headless",
                "MAXIVMAC_SANITIZE": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "macos",
            "configurePreset": "macos"
        },
        {
            "name": "macos-headless",
            "configurePreset": "macos-headless"
        },
        {
            "name": "macos-coverage",
            "configurePreset": "macos-coverage"
        },
        {
            "name": "macos-asan",
            "configurePreset": "macos-asan"
        }
    ]
}