{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "macos",
            "displayName": "macOS",
            "description": "Release build on macOS",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-coverage",
            "displayName": "macOS (Coverage)",
            "description": "Debug build with code-coverage instrumentation",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "MAXIVMAC_COVERAGE": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-asan",
            "displayName": "macOS (ASan/UBSan)",
            "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/bld/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "MAXIVMAC_SANITIZE": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "macos",
            "configurePreset": "macos"
        },
        {
            "name": "macos-coverage",
            "configurePreset": "macos-coverage"
        },
        {
            "name": "macos-asan",
            "configurePreset": "macos-asan"
        }
    ]
}