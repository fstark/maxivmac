    6  sword    processor
    8  Boolean  hasFPU
    9  Boolean  hasColorQD
    10 sword    keyBoardType
    12 sword    atDrvrVersNum
    14 sword    sysVRefNum
}

# Custom: pre-Multifinder launch trap

struct LaunchParam {
	0 PStr name
	4 sword flags
}

