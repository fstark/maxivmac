# types.def — Classic Mac OS structure definitions for maxivmac
#
# Loaded by TypeRegistry at startup.  Field offsets are decimal bytes
# from the start of the struct.  Types are primitives (byte, sword, etc.)
# or previously-defined struct names.
#
# Source: THINK C 5 "Apple #includes" headers (Files.h, Quickdraw.h, Windows.h)

# ── Small composites ────────────────────

struct Point {
    0  sword    v
    2  sword    h
}

struct Rect {
    0  sword    top
    2  sword    left
    4  sword    bottom
    6  sword    right
}

# ── Finder Info ──────────────────────────

struct FInfo {
    0  OSType   fdType
    4  OSType   fdCreator
    8  word     fdFlags
    10 Point    fdLocation
    14 sword    fdFldr
}

struct FXInfo {
    0  sword    fdIconID
    2  sword    fdUnused[3]
    8  sbyte    fdScript
    9  sbyte    fdXFlags
    10 sword    fdComment
    12 long     fdPutAway
}

struct DInfo {
    0  Rect     frRect
    8  word     frFlags
    10 Point    frLocation
    14 sword    frView
}

struct DXInfo {
    0  Point    frScroll
    4  long     frOpenChain
    8  sbyte    frScript
    9  sbyte    frXFlags
    10 sword    frComment
    12 long     frPutAway
}

# ── ParamBlockHeader ────────────────────
# Shared prefix for all File Manager param blocks.

struct ParamBlockHeader {
    0  Ptr      qLink
    4  sword    qType
    6  word     ioTrap
    8  Ptr      ioCmdAddr
    12 ProcPtr  ioCompletion
    16 OSErr    ioResult
    18 PStr     ioNamePtr
    22 sword    ioVRefNum
}

# ── File Manager param blocks ───────────

struct IOParam {
    0  ParamBlockHeader header
    24 sword    ioRefNum
    26 sbyte    ioVersNum
    27 sbyte    ioPermssn
    28 Ptr      ioMisc
    32 Ptr      ioBuffer
    36 long     ioReqCount
    40 long     ioActCount
    44 sword    ioPosMode
    46 slong    ioPosOffset
}

struct HIOParam {
    0  ParamBlockHeader header
    24 sword    ioRefNum
    26 sbyte    ioVersNum
    27 sbyte    ioPermssn
    28 Ptr      ioMisc
    32 Ptr      ioBuffer
    36 long     ioReqCount
    40 long     ioActCount
    44 sword    ioPosMode
    46 slong    ioPosOffset
}

# Synthetic: PBHOpen/PBHOpenRF/PBHRename use fields from both the ioParam
# arm (ioPermssn at 27) and the fileParam arm (ioDirID at 48) of the
# HParamBlockRec union.  No single Mac struct captures this.
# TODO: support qualified union arm fields in show-in/show-out
#       (e.g. "fileParam.ioDirID") so we can use the real union type.
struct HOpenParam {
    0  ParamBlockHeader header
    24 sword    ioRefNum
    26 sbyte    ioVersNum
    27 sbyte    ioPermssn
    28 Ptr      ioMisc
    48 long     ioDirID
}

struct FileParam {
    0  ParamBlockHeader header
    24 sword    ioFRefNum
    26 sbyte    ioFVersNum
    27 sbyte    filler1
    28 sword    ioFDirIndex
    30 sbyte    ioFlAttrib
    31 sbyte    ioFlVersNum
    32 FInfo    ioFlFndrInfo
    48 long     ioFlNum
    52 word     ioFlStBlk
    54 slong    ioFlLgLen
    58 slong    ioFlPyLen
    62 word     ioFlRStBlk
    64 slong    ioFlRLgLen
    68 slong    ioFlRPyLen
    72 long     ioFlCrDat
    76 long     ioFlMdDat
}

struct HVolumeParam {
    0  ParamBlockHeader header
    24 sword    ioFRefNum
    26 sbyte    filler1
    27 sbyte    filler2
    28 sword    ioVolIndex
    30 long     ioVCrDate
    34 long     ioVLsMod
    38 sword    ioVAtrb
    40 sword    ioVNmFls
    42 word     ioVBitMap
    44 word     ioAllocPtr
    46 word     ioVNmAlBlks
    48 long     ioVAlBlkSiz
    52 long     ioVClpSiz
    56 word     ioAlBlSt
    58 long     ioVNxtCNID
    62 word     ioVFrBlk
    64 sword    ioVSigWord
    66 sword    ioVDrvInfo
    68 sword    ioVDRefNum
    70 sword    ioVFSID
    72 long     ioVBkUp
    76 sword    ioVSeqNum
    78 long     ioVWrCnt
    82 long     ioVFilCnt
    86 long     ioVDirCnt
    90 long     ioVFndrInfo0
    94 long     ioVFndrInfo1
    98 long     ioVFndrInfo2
    102 long    ioVFndrInfo3
    106 long    ioVFndrInfo4
    110 long    ioVFndrInfo5
    114 long    ioVFndrInfo6
    118 long    ioVFndrInfo7
}

struct VolumeParam {
    0  ParamBlockHeader header
    24 sword    ioFRefNum
    26 sbyte    filler1
    27 sbyte    filler2
    28 sword    ioVolIndex
    30 long     ioVCrDate
    34 long     ioVLsMod
    38 sword    ioVAtrb
    40 sword    ioVNmFls
    42 word     ioVBitMap
    44 word     ioAllocPtr
    46 word     ioVNmAlBlks
    48 long     ioVAlBlkSiz
    52 long     ioVClpSiz
    56 word     ioAlBlSt
    58 long     ioVNxtCNID
    62 word     ioVFrBlk
